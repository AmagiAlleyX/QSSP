{
  "manifest_version": 3,
  "name": "QSSP - 秋牲起始页",
  "version": "0.0.1",
  "description": "一个精美的个性化浏览器起始页，拥有 Live2D 看板娘、快捷导航、专注时钟、音乐播放器等丰富功能。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "favicon.ico",
    "48": "favicon.ico",
    "128": "favicon.ico"
  },
  "permissions": [
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
